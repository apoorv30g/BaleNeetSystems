NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://postgres:password@localhost:5432/loanconnect
REDIS_URL=redis://localhost:6379

JWT_SECRET=replace_with_64_char_random_secret

FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000
CORS_ORIGIN_SUFFIXES=
SERVER_URL=http://localhost:4000

EXOTEL_ACCOUNT_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_FROM_NUMBER=
EXOTEL_API_BASE=https://api.in.exotel.com
EXOTEL_OUTBOUND_COST_PER_MINUTE_INR=0.60
EXOTEL_INBOUND_COST_PER_MINUTE_INR=0.20
EXOTEL_ATTEMPT_COST_INR=0.06
EXOTEL_CHANNEL_MONTHLY_COST_INR=1500
EXOTEL_CHANNEL_COUNT=1
EXOTEL_MIN_MONTHLY_BILLING_INR=20000

GEMINI_API_KEY=
SARVAM_API_KEY=
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=multi

# TTS voice settings (bulbul:v3 recommended)
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=shubh
SARVAM_TTS_LANGUAGE=hi-IN
# pace: 0.5 (slow) to 1.5 (fast) — 0.9 feels natural on calls
SARVAM_TTS_PACE=0.9
# loudness: amplification multiplier — 1.5 recommended for phone calls
SARVAM_TTS_LOUDNESS=1.5

CALL_WINDOW_START=9
CALL_WINDOW_END=20
MAX_CALL_ATTEMPTS=3
MAX_CONCURRENT_CALLS=20
CALL_DISPATCH_SPACING_SECONDS=0
CALL_CHANNEL_HOLD_MAX_SECONDS=0
CALL_CHANNEL_POLL_MS=1000
CALL_RETRY_DELAY_MINUTES=360

LOAN_APP_URL=https://yourapp.com/apply
PAYMENT_LINK_BASE=https://yourapp.com/pay
SUPPORT_PHONE=
VOICEBOT_TOKEN=

# Brand identity spoken by the AI on calls (identity line, disclosure default, pronunciation
# hint, and the Exotel fallback greeting). Does not affect the TEZ_* playbooks, which are
# hardcoded to the TezCredit journey regardless of this value.
BRAND_NAME=ASAP Finance
ASSISTANT_NAME=Sneha

# Webhook security — set to a random secret and pass as ?secret= on Exotel callback URLs
EXOTEL_WEBHOOK_SECRET=

# LLM circuit breaker — open after N consecutive failures, reset after M ms
LLM_CIRCUIT_THRESHOLD=5
LLM_CIRCUIT_RESET_MS=30000

# Upload limits
UPLOAD_MAX_BYTES=52428800
UPLOAD_MAX_ROWS=10000

# Lead enqueue batch limit (rows fetched per queue-calls request)
ENQUEUE_BATCH_LIMIT=5000

# Audio PCM cache size (number of entries before LRU eviction)
VOICEBOT_PCM_CACHE_MAX=200

# Database connection pool
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=3000
DB_MAX_USES=7500

# JWT expiry (e.g. 8h, 1d) — keep short; no refresh token flow currently
JWT_EXPIRY=8h

# Provider fetch timeouts
DEEPGRAM_TIMEOUT_MS=15000
SARVAM_TTS_TIMEOUT_MS=12000

# Worker health server port
WORKER_HEALTH_PORT=4001
